# Anchor / Rust build artifacts
.anchor
target
**/*.rs.bk

# Solana local validators / ledgers
test-ledger
.surfpool

# Node / package managers
node_modules
.yarn
.pnp.*
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# Secrets & keypairs — never commit these
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.keystore
wallet.json
id.json
*-wallet.json
# Any Solana keypair (program/wallet/validator) anywhere in the tree
*-keypair.json
keypair.json
**/test-ledger/
keypairs/
# Mnemonics / seed phrases / generic secret dumps
*.mnemonic
mnemonic.txt
seed.txt
secret*.json
secrets.json
.secrets/

# Dumped / large binaries (e.g. artifacts/flash_ref.so — reproducible via `solana program dump`)
artifacts/
*.so

# Frontend build outputs (demo UI in app/)
.next
out
dist
build
.turbo
.vercel
*.tsbuildinfo

# Logs & coverage
*.log
logs
coverage

# Editor / OS
.DS_Store
Thumbs.db
.idea
.vscode
*.swp
